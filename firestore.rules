rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 任何人可讀，但只有登入者可寫入 word cloud 詞彙
    match /words/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 其他集合預設禁止存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
